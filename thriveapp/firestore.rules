rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get the current user's profile data
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    // Helper functions for roles
    function isPT() {
      return isSignedIn() && getUserData().get('role', 'client') == 'pt';
    }

    function isAdmin() {
      return isSignedIn() && getUserData().get('role', 'client') == 'admin';
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Users can read their own profile; PTs and Admins can read all profiles; anyone can read PT or Admin profiles
      // (needed for PT code lookup which queries role in ['pt', 'admin']); clients can read their assigned PT's profile
      allow read: if (resource.data.role in ['pt', 'admin']) ||
                    (isSignedIn() && (request.auth.uid == userId || isPT() || isAdmin() || getUserData().get('assignedPtId', '') == userId));
      
      // Users can create their own profile during signup (default role is 'client')
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'client';
      
      // Users can update their own profile (cannot change their own role)
      // Admins can update any profile/role
      // PTs can update assignedPtId if they are assigning to themselves or null
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        (isPT() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedPtId']))
      );
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // --- BOOKINGS COLLECTION ---
    match /bookings/{bookingId} {
      // 1. Users can read their own bookings
      // 2. PTs and Admins can read all bookings
      // 3. ANY signed-in user can read CONFIRMED bookings for availability/capacity checks
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isPT() || 
        isAdmin() ||
        resource.data.status == 'confirmed'
      );
      
      // Users can create bookings for themselves
      // PTs can create 'block' type bookings or bookings for themselves as PT
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        (isPT() && (request.resource.data.type == 'block' || request.resource.data.ptId == request.auth.uid)) ||
        isAdmin()
      );
      
      // Users can cancel (update status) their own bookings
      // PTs and Admins can update any booking
      // Specifically allow PTs to update bookings where they are the assigned PT
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.ptId == request.auth.uid ||
        isPT() || 
        isAdmin()
      );
      
      // Only admins can delete bookings (usually we just cancel them)
      allow delete: if isAdmin();
    }

    // --- GROUP SESSIONS COLLECTION ---
    match /group_sessions/{sessionId} {
      // All authenticated users can see group sessions
      allow read: if isSignedIn();
      
      // Only admins can manage group sessions
      allow write: if isAdmin();
    }

    // --- RECURRING TEMPLATES COLLECTION ---
    match /recurring_templates/{templateId} {
      // Users can read templates they are part of (either the client or the PT)
      // Admins can read all templates
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.ptId == request.auth.uid ||
        isAdmin()
      );

      // PTs can create templates for their clients
      // Admins can create templates for anyone
      allow create: if isSignedIn() && (
        (isPT() && request.resource.data.ptId == request.auth.uid) ||
        isAdmin()
      );

      // PTs and Admins can update/cancel templates
      allow update: if isSignedIn() && (
        (isPT() && resource.data.ptId == request.auth.uid) ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // --- GROUPS COLLECTION ---
    match /groups/{groupId} {
      // Any signed-in user can read groups (needs it to hydrate class names)
      allow read: if isSignedIn();
      
      // PTs can create groups they own
      allow create: if isPT() && request.resource.data.ptId == request.auth.uid;
      
      // PTs can update/delete their own groups. Users can update to join (add to memberIds).
      allow update: if isSignedIn() && (
        (isPT() && resource.data.ptId == request.auth.uid) ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
      );
      
      allow delete: if (isPT() && resource.data.ptId == request.auth.uid) || isAdmin();
    }

    // --- GROUP INVITES COLLECTION ---
    match /group_invites/{inviteId} {
      // Anyone signed in can read invites
      allow read: if isSignedIn();
      
      // PTs can create invites
      allow create: if isPT();
      
      // Anyone can update (to accept/decline)
      allow update: if isSignedIn();
      
      allow delete: if isPT() || isAdmin();
    }

    // --- SETTINGS COLLECTION ---
    match /settings/{document=**} {
      // Anyone can read global settings for sign up verification
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ERROR LOGS COLLECTION ---
    match /error_logs/{errorId} {
      // Anyone can create an error log (errors happen before login too)
      allow create: if true;
      
      // Only admins can read logged errors
      allow read: if isAdmin();
    }
  }
}
